{
  "name": "ai-hub",
  "version": "1.1.0",
  "description": "Multi-AI Chat Aggregator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --x64",
    "build:arm64": "electron-builder --mac --arm64",
    "build:universal": "electron-builder --mac --x64 --arm64",
    "dev": "NODE_ENV=development electron ."
  },
  "build": {
    "appId": "com.aihub.app",
    "productName": "AI Hub",
    "files": [
      "main.js",
      "preload.js",
      "preload-webview.js",
      "config-default.json",
      "adapters/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    }
  },
  "keywords": ["ai", "chatgpt", "claude", "gemini"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
